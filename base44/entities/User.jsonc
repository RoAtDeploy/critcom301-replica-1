{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "assessor",
        "line_manager"
      ],
      "default": "assessor",
      "description": "Primary role used by platform security (derived from roles). Admin grants full access."
    },
    "roles": {
      "type": "array",
      "description": "All user types assigned to this user",
      "items": {
        "type": "string",
        "enum": [
          "admin",
          "assessor",
          "line_manager"
        ]
      },
      "default": [
        "assessor"
      ]
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    }
  },
  "required": []
}